<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="LgColorCanvas">#F6F7F9</Color>
    <Color x:Key="LgColorSurface">#FFFFFFFF</Color>
    <Color x:Key="LgColorSurfaceAlt">#EEF2F6</Color>
    <Color x:Key="LgColorInk">#17202A</Color>
    <Color x:Key="LgColorMuted">#637083</Color>
    <Color x:Key="LgColorAccent">#0F7B6C</Color>
    <Color x:Key="LgColorAccentSoft">#DDF3EE</Color>
    <Color x:Key="LgColorWarning">#A15C00</Color>
    <Color x:Key="LgColorError">#B42318</Color>

    <SolidColorBrush x:Key="LgBrushCanvas" Color="{StaticResource LgColorCanvas}" />
    <SolidColorBrush x:Key="LgBrushSurface" Color="{StaticResource LgColorSurface}" />
    <SolidColorBrush x:Key="LgBrushSurfaceAlt" Color="{StaticResource LgColorSurfaceAlt}" />
    <SolidColorBrush x:Key="LgBrushInk" Color="{StaticResource LgColorInk}" />
    <SolidColorBrush x:Key="LgBrushMuted" Color="{StaticResource LgColorMuted}" />
    <SolidColorBrush x:Key="LgBrushAccent" Color="{StaticResource LgColorAccent}" />
    <SolidColorBrush x:Key="LgBrushAccentSoft" Color="{StaticResource LgColorAccentSoft}" />
    <SolidColorBrush x:Key="LgBrushWarning" Color="{StaticResource LgColorWarning}" />
    <SolidColorBrush x:Key="LgBrushError" Color="{StaticResource LgColorError}" />

    <CornerRadius x:Key="LgRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="LgRadiusMd">6</CornerRadius>
    <CornerRadius x:Key="LgRadiusLg">8</CornerRadius>

    <Style x:Key="LgNavButton" TargetType="Button">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{StaticResource LgBrushInk}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource LgRadiusMd}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource LgBrushSurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource LgBrushAccentSoft}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LgCommandButton" TargetType="Button">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="{StaticResource LgBrushInk}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource LgBrushInk}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LgSecondaryButton" TargetType="Button" BasedOn="{StaticResource LgCommandButton}">
        <Setter Property="Background" Value="{StaticResource LgBrushSurface}" />
        <Setter Property="Foreground" Value="{StaticResource LgBrushInk}" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
    </Style>

    <Style x:Key="LgTextBox" TargetType="TextBox">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="BorderBrush" Value="#CBD5E1" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource LgBrushSurface}" />
    </Style>

    <Style x:Key="LgCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LgBrushSurface}" />
        <Setter Property="BorderBrush" Value="#E2E8F0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource LgRadiusLg}" />
    </Style>
</ResourceDictionary>
