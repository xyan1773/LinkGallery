<Window x:Class="LinkGallery.Desktop.PairDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配对手机"
        Width="500"
        Height="650"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="OnWindowMouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DesignTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="16"
            Padding="28"
            Background="{StaticResource LgBrushSurface}"
            BorderBrush="{StaticResource LgBrushLine}"
            BorderThickness="1"
            CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LgBrushInk}"
                               Text="配对手机" />
                    <TextBlock x:Name="SubtitleText"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="在手机 LinkGallery 的设备页扫描二维码" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="38"
                        Height="38"
                        Padding="0"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="13"
                        Content="&#xE8BB;"
                        Click="OnCloseClick"
                        Style="{StaticResource LgSecondaryButton}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,18">
                <StackPanel x:Name="QrPanel">
                    <Border Width="300"
                            Height="300"
                            Padding="16"
                            HorizontalAlignment="Center"
                            Background="White"
                            BorderBrush="{StaticResource LgBrushLine}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <Image x:Name="QrImage" Stretch="Uniform" />
                    </Border>
                    <TextBlock x:Name="QrStatusText"
                               Margin="0,18,0,0"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="正在等待手机扫描…" />
                    <ProgressBar Height="4"
                                 Width="180"
                                 Margin="0,12,0,0"
                                 HorizontalAlignment="Center"
                                 IsIndeterminate="True" />
                </StackPanel>

                <StackPanel x:Name="ManualCodePanel" Visibility="Collapsed">
                    <Border Padding="20"
                            Background="{StaticResource LgBrushSurfaceAlt}"
                            BorderBrush="{StaticResource LgBrushLine}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock x:Name="ManualTitleText"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LgBrushInk}"
                                       Text="输入手机上的六位码" />
                            <TextBlock x:Name="ManualBodyText"
                                       Margin="0,8,0,18"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       TextWrapping="Wrap"
                                       Text="手机打开配对窗口后会显示一次性六位码，电脑会在当前局域网中自动找到它。" />
                            <TextBox x:Name="CodeTextBox"
                                     Height="58"
                                     MaxLength="6"
                                     FontSize="24"
                                     FontWeight="SemiBold"
                                     HorizontalContentAlignment="Center"
                                     AutomationProperties.AutomationId="PairingCodeTextBox"
                                     Style="{StaticResource LgTextBox}" />
                            <TextBlock x:Name="ManualErrorText"
                                       Margin="2,8,0,0"
                                       Foreground="#FFC62828"
                                       TextWrapping="Wrap" />
                            <Button x:Name="FindByCodeButton"
                                    Margin="0,18,0,0"
                                    Height="48"
                                    Content="查找并配对"
                                    Click="OnConfirmManualCode"
                                    Style="{StaticResource LgCommandButton}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="CannotScanButton"
                        HorizontalAlignment="Left"
                        Content="无法扫描二维码"
                        Click="OnCannotScanClick"
                        Style="{StaticResource LgSecondaryButton}" />
                <Button x:Name="ManualIpButton"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Content="输入 IP"
                        Click="OnManualIpClick"
                        Style="{StaticResource LgSecondaryButton}" />
            </Grid>
        </Grid>
    </Border>
</Window>
