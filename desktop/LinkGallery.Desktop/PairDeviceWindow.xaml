<Window x:Class="LinkGallery.Desktop.PairDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配对手机"
        Width="500"
        Height="650"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="OnWindowMouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DesignTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="16"
            Padding="28"
            Background="{StaticResource LgBrushSurface}"
            BorderBrush="{StaticResource LgBrushLine}"
            BorderThickness="1"
            CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LgBrushInk}"
                               Text="配对手机" />
                    <TextBlock x:Name="SubtitleText"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="在手机 LinkGallery 的设备页扫描二维码" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="38"
                        Height="38"
                        Padding="0"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="13"
                        Content="&#xE8BB;"
                        Click="OnCloseClick"
                        Style="{StaticResource LgSecondaryButton}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,18,0,16">
                <StackPanel>
                    <Border Width="270"
                            Height="270"
                            Padding="16"
                            HorizontalAlignment="Center"
                            Background="White"
                            BorderBrush="{StaticResource LgBrushLine}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <Image x:Name="QrImage" Stretch="Uniform" />
                    </Border>
                    <TextBlock x:Name="PairingCodeLabel"
                               Margin="0,14,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="配对码" />
                    <TextBlock x:Name="PairingCodeText"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontSize="30"
                               FontWeight="SemiBold"
                               FontFamily="Consolas"
                               Foreground="{StaticResource LgBrushInk}"
                               Text="123 456" />
                    <TextBlock x:Name="QrStatusText"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="正在等待手机扫描…" />
                    <ProgressBar Height="4"
                                 Width="180"
                                 Margin="0,9,0,0"
                                 HorizontalAlignment="Center"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CodeHintText"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource LgBrushMuted}"
                           FontSize="12"
                           Text="无法扫码时，在手机上输入六位码" />
                <Button x:Name="ManualIpButton"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Content="输入 IP"
                        Click="OnManualIpClick"
                        Style="{StaticResource LgSecondaryButton}" />
            </Grid>
        </Grid>
    </Border>
</Window>
