<Window x:Class="LinkGallery.Desktop.PairingCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pair device"
        Width="390"
        Height="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="Pair Android device" />
        <TextBlock Grid.Row="1"
                   Margin="0,10,0,16"
                   TextWrapping="Wrap"
                   Foreground="#666666"
                   Text="Enter the six-digit code currently shown in LinkGallery on the phone." />
        <TextBox x:Name="CodeTextBox"
                 Grid.Row="2"
                 Height="42"
                 MaxLength="6"
                 FontSize="20"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 AutomationProperties.AutomationId="PairingCodeTextBox" />
        <TextBlock x:Name="ErrorText"
                   Grid.Row="3"
                   Margin="0,8,0,0"
                   Foreground="#C62828"
                   TextWrapping="Wrap" />
        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="90"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Content="Cancel" />
            <Button Width="90"
                    IsDefault="True"
                    Click="OnConfirm"
                    AutomationProperties.AutomationId="ConfirmPairingButton"
                    Content="Pair" />
        </StackPanel>
    </Grid>
</Window>
