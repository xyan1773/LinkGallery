<Window x:Class="LinkGallery.Desktop.PairingCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入配对码"
        Width="470"
        Height="390"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="OnWindowMouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DesignTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="16"
            Padding="28"
            Background="{StaticResource LgBrushSurface}"
            BorderBrush="{StaticResource LgBrushLine}"
            BorderThickness="1"
            CornerRadius="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock FontSize="25"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource LgBrushInk}"
                       Text="输入手机配对码" />
            <TextBlock Grid.Row="1"
                       Margin="0,10,0,18"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource LgBrushMuted}"
                       Text="输入手机 LinkGallery 当前显示的一次性六位码。" />
            <TextBox x:Name="CodeTextBox"
                     Grid.Row="2"
                     Height="58"
                     MaxLength="6"
                     FontSize="24"
                     FontWeight="SemiBold"
                     HorizontalContentAlignment="Center"
                     AutomationProperties.AutomationId="PairingCodeTextBox"
                     Style="{StaticResource LgTextBox}" />
            <TextBlock x:Name="ErrorText"
                       Grid.Row="3"
                       Margin="2,8,0,0"
                       Foreground="#FFC62828"
                       TextWrapping="Wrap" />
            <StackPanel Grid.Row="4"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button MinWidth="96"
                        IsCancel="True"
                        Content="取消"
                        Style="{StaticResource LgSecondaryButton}" />
                <Button MinWidth="112"
                        Margin="10,0,0,0"
                        IsDefault="True"
                        Click="OnConfirm"
                        AutomationProperties.AutomationId="ConfirmPairingButton"
                        Content="配对"
                        Style="{StaticResource LgCommandButton}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
