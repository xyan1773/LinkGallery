<Window x:Class="LinkGallery.Desktop.MediaDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="媒体详情"
        Width="1120"
        Height="760"
        MinWidth="760"
        MinHeight="520"
        Background="#111827"
        KeyDown="OnKeyDown"
        Closed="OnClosed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="20,16">
                <Button x:Name="PreviousButton"
                        Width="88"
                        Padding="8"
                        HorizontalAlignment="Left"
                        Click="OnPreviousClick"
                        Content="← 上一项" />
                <TextBlock x:Name="PositionText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#D1D5DB" />
                <Button x:Name="NextButton"
                        Width="88"
                        Padding="8"
                        HorizontalAlignment="Right"
                        Click="OnNextClick"
                        Content="下一项 →" />
            </Grid>

            <Grid Grid.Row="1" Margin="20,0">
                <Border x:Name="PhotoPanel"
                        Background="#030712"
                        ClipToBounds="True"
                        Visibility="Collapsed">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="OnPhotoMouseWheel">
                        <Image x:Name="PhotoImage"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="PhotoScale" ScaleX="1" ScaleY="1" />
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Border>

                <Grid x:Name="VideoPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <MediaElement x:Name="VideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  MediaOpened="OnVideoOpened"
                                  MediaEnded="OnVideoEnded"
                                  MediaFailed="OnVideoFailed" />
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PlayPauseButton"
                                Width="72"
                                Padding="8"
                                Click="OnPlayPauseClick"
                                Content="播放" />
                        <Slider x:Name="VideoProgress"
                                Grid.Column="1"
                                Margin="14,0"
                                VerticalAlignment="Center"
                                Minimum="0"
                                ValueChanged="OnVideoProgressChanged" />
                        <TextBlock x:Name="VideoTimeText"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Foreground="#D1D5DB"
                                   Text="00:00 / 00:00" />
                    </Grid>
                </Grid>

                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ProgressBar Width="180"
                                 Height="4"
                                 IsIndeterminate="True" />
                    <TextBlock x:Name="LoadingText"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Foreground="#D1D5DB"
                               Text="正在加载…" />
                </StackPanel>

                <StackPanel x:Name="ErrorPanel"
                            MaxWidth="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F9FAFB"
                               Text="无法打开此媒体"
                               TextAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Margin="0,10,0,0"
                               Foreground="#D1D5DB"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Margin="20,12,20,16"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <Button x:Name="ZoomOutButton"
                        Width="72"
                        Padding="8"
                        Click="OnZoomOutClick"
                        Content="缩小"
                        Visibility="Collapsed" />
                <Button x:Name="ZoomResetButton"
                        Width="72"
                        Margin="8,0"
                        Padding="8"
                        Click="OnZoomResetClick"
                        Content="适合"
                        Visibility="Collapsed" />
                <Button x:Name="ZoomInButton"
                        Width="72"
                        Padding="8"
                        Click="OnZoomInClick"
                        Content="放大"
                        Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <Border Grid.Column="1"
                Padding="24"
                Background="#F9FAFB">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="FileNameText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <Border Margin="0,14,0,22"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Background="#E5E7EB"
                            CornerRadius="12">
                        <TextBlock x:Name="AvailabilityText"
                                   Foreground="#374151" />
                    </Border>

                    <TextBlock FontWeight="SemiBold" Text="拍摄时间" />
                    <TextBlock x:Name="TakenAtText" Margin="0,5,0,16" Foreground="#4B5563" />
                    <TextBlock FontWeight="SemiBold" Text="尺寸" />
                    <TextBlock x:Name="DimensionsText" Margin="0,5,0,16" Foreground="#4B5563" />
                    <TextBlock FontWeight="SemiBold" Text="大小" />
                    <TextBlock x:Name="SizeText" Margin="0,5,0,16" Foreground="#4B5563" />
                    <TextBlock FontWeight="SemiBold" Text="来源" />
                    <TextBlock x:Name="SourceText"
                               Margin="0,5,0,16"
                               Foreground="#4B5563"
                               TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="相对路径" />
                    <TextBlock x:Name="PathText"
                               Margin="0,5,0,16"
                               Foreground="#4B5563"
                               TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="类型" />
                    <TextBlock x:Name="TypeText" Margin="0,5,0,16" Foreground="#4B5563" />

                    <Separator Margin="0,8,0,16" />
                    <TextBlock Foreground="#6B7280"
                               Text="只读预览 · 不会修改手机中的原件"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
