<Window x:Class="LinkGallery.Desktop.MediaDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="媒体详情"
        Width="1120"
        Height="760"
        MinWidth="760"
        MinHeight="520"
        Background="#1C1C1E"
        KeyDown="OnKeyDown"
        Closed="OnClosed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="20,16">
                <Button x:Name="PreviousButton"
                        AutomationProperties.AutomationId="PreviousButton"
                        Width="88"
                        Height="44"
                        HorizontalAlignment="Left"
                        Click="OnPreviousClick"
                        Content="← 上一项"
                        Background="#2FFFFFFF"
                        BorderBrush="#35FFFFFF"
                        Foreground="White"
                        Style="{StaticResource LgSecondaryButton}" />
                <TextBlock x:Name="PositionText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#CCFFFFFF" />
                <Button x:Name="NextButton"
                        AutomationProperties.AutomationId="NextButton"
                        Width="88"
                        Height="44"
                        HorizontalAlignment="Right"
                        Click="OnNextClick"
                        Content="下一项 →"
                        Background="#2FFFFFFF"
                        BorderBrush="#35FFFFFF"
                        Foreground="White"
                        Style="{StaticResource LgSecondaryButton}" />
            </Grid>

            <Grid Grid.Row="1" Margin="20,0">
                <Border x:Name="PhotoPanel"
                        AutomationProperties.AutomationId="PhotoPanel"
                        Background="#000000"
                        CornerRadius="14"
                        ClipToBounds="True"
                        Visibility="Collapsed">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="OnPhotoMouseWheel">
                        <Image x:Name="PhotoImage"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="PhotoScale" ScaleX="1" ScaleY="1" />
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Border>

                <Grid x:Name="VideoPanel"
                      AutomationProperties.AutomationId="VideoPanel"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <MediaElement x:Name="VideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  Volume="0.8"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  MediaOpened="OnVideoOpened"
                                  MediaEnded="OnVideoEnded"
                                  MediaFailed="OnVideoFailed"
                                  BufferingStarted="OnVideoBufferingStarted"
                                  BufferingEnded="OnVideoBufferingEnded" />
                    <TextBlock x:Name="VideoStatusText"
                               AutomationProperties.AutomationId="VideoStatusText"
                               Grid.Row="1"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               Foreground="#CCFFFFFF"
                               Text="正在加载视频…" />
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PlayPauseButton"
                                AutomationProperties.AutomationId="PlayPauseButton"
                                Width="72"
                                IsEnabled="False"
                                Click="OnPlayPauseClick"
                                Content="播放"
                                Style="{StaticResource LgSecondaryButton}" />
                        <Slider x:Name="VideoProgress"
                                AutomationProperties.AutomationId="VideoProgress"
                                Grid.Column="1"
                                Margin="14,0"
                                VerticalAlignment="Center"
                                Minimum="0"
                                IsMoveToPointEnabled="True"
                                IsEnabled="False"
                                ValueChanged="OnVideoProgressChanged" />
                        <TextBlock x:Name="VideoTimeText"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Foreground="#CCFFFFFF"
                                   Text="00:00 / 00:00" />
                        <StackPanel Grid.Column="3"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#CCFFFFFF"
                                       Text="音量" />
                            <Slider x:Name="VideoVolume"
                                    AutomationProperties.AutomationId="VideoVolume"
                                    Width="88"
                                    VerticalAlignment="Center"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0.8"
                                    ValueChanged="OnVideoVolumeChanged" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel x:Name="LoadingPanel"
                            AutomationProperties.AutomationId="LoadingPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ProgressBar Width="180"
                                 Height="4"
                                 IsIndeterminate="True" />
                    <TextBlock x:Name="LoadingText"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Foreground="#CCFFFFFF"
                               Text="正在加载…" />
                </StackPanel>

                <StackPanel x:Name="ErrorPanel"
                            AutomationProperties.AutomationId="ErrorPanel"
                            MaxWidth="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="无法打开此媒体"
                               TextAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Margin="0,10,0,0"
                               Foreground="#CCFFFFFF"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Margin="20,12,20,16"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <Button x:Name="ZoomOutButton"
                        AutomationProperties.AutomationId="ZoomOutButton"
                        Width="72"
                        Click="OnZoomOutClick"
                        Content="缩小"
                        Style="{StaticResource LgSecondaryButton}"
                        Visibility="Collapsed" />
                <Button x:Name="ZoomResetButton"
                        AutomationProperties.AutomationId="ZoomResetButton"
                        Width="72"
                        Margin="8,0"
                        Click="OnZoomResetClick"
                        Content="适合"
                        Style="{StaticResource LgSecondaryButton}"
                        Visibility="Collapsed" />
                <Button x:Name="ZoomActualButton"
                        AutomationProperties.AutomationId="ZoomActualButton"
                        Width="72"
                        Margin="0,0,8,0"
                        Click="OnZoomActualClick"
                        Content="100%"
                        Style="{StaticResource LgSecondaryButton}"
                        Visibility="Collapsed" />
                <Button x:Name="ZoomInButton"
                        AutomationProperties.AutomationId="ZoomInButton"
                        Width="72"
                        Click="OnZoomInClick"
                        Content="放大"
                        Style="{StaticResource LgSecondaryButton}"
                        Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <Border Grid.Column="1"
                Padding="24"
                Background="{StaticResource LgBrushSurfaceAlt}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="FileNameText"
                               AutomationProperties.AutomationId="FileNameText"
                               FontSize="21"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <Border Margin="0,14,0,22"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                             Background="{StaticResource LgBrushAccentSoft}"
                             CornerRadius="999">
                        <TextBlock x:Name="AvailabilityText"
                                   Foreground="{StaticResource LgBrushAccent}" />
                    </Border>

                    <TextBlock FontWeight="SemiBold" Text="拍摄时间" />
                    <TextBlock x:Name="TakenAtText" Margin="0,5,0,16" Foreground="{StaticResource LgBrushMuted}" />
                    <TextBlock FontWeight="SemiBold" Text="尺寸" />
                    <TextBlock x:Name="DimensionsText" Margin="0,5,0,16" Foreground="{StaticResource LgBrushMuted}" />
                    <TextBlock FontWeight="SemiBold" Text="大小" />
                    <TextBlock x:Name="SizeText" Margin="0,5,0,16" Foreground="{StaticResource LgBrushMuted}" />
                    <TextBlock FontWeight="SemiBold" Text="来源" />
                    <TextBlock x:Name="SourceText"
                               Margin="0,5,0,16"
                               Foreground="{StaticResource LgBrushMuted}"
                               TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="相对路径" />
                    <TextBlock x:Name="PathText"
                               Margin="0,5,0,16"
                               Foreground="{StaticResource LgBrushMuted}"
                               TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="类型" />
                    <TextBlock x:Name="TypeText" Margin="0,5,0,16" Foreground="{StaticResource LgBrushMuted}" />

                    <Separator Margin="0,8,0,16" />
                    <TextBlock Foreground="{StaticResource LgBrushMuted}"
                               Text="只读预览 · 不会修改手机中的原件"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
