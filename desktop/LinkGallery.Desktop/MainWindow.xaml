<Window x:Class="LinkGallery.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkGallery"
        Width="1100"
        Height="720"
        MinWidth="800"
        MinHeight="500"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="24" Background="#F3F4F6">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="LinkGallery" />
                <TextBlock Margin="0,28,0,0" FontWeight="SemiBold" Text="我的手机" />
                <ListBox x:Name="PairedDevicesList"
                         Margin="0,10,0,0"
                         ItemsSource="{Binding PairedDeviceRows}"
                         SelectionChanged="OnPairedDeviceSelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         MaxHeight="170">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6"
                                    Padding="8"
                                    Background="#E5E7EB"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="11"
                                               Foreground="#4B5563"
                                               Text="{Binding Detail}" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               Text="{Binding StatusText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Margin="0,10,0,0"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Text="通过同一 Wi-Fi 只读浏览手机中的照片和视频。" />
                <Separator Margin="0,22,0,18" />
                <TextBlock FontWeight="SemiBold" Text="连接地址" />
                <TextBox x:Name="AddressTextBox"
                         Margin="0,8,0,0"
                         Padding="8"
                         Text="192.168.1.20:39570"
                         TextChanged="OnAddressTextChanged"
                         ToolTip="手机显示的 IP 地址和端口" />
                <TextBlock x:Name="AddressHintText"
                           Margin="0,7,0,0"
                           FontSize="11"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Text="模拟器：先执行 adb forward，再输入 127.0.0.1:39570；不要输入 10.0.2.x。" />
                <Button x:Name="ConnectButton"
                        Margin="0,12,0,0"
                        Padding="8"
                        Click="OnConnectClick"
                        Content="连接" />
                <Button x:Name="DisconnectButton"
                        Margin="0,8,0,0"
                        Padding="8"
                        IsEnabled="False"
                        Click="OnDisconnectClick"
                        Content="断开" />
                <Button Margin="0,8,0,0"
                        Padding="8"
                        Click="OnClearCacheClick"
                        Content="清理缩略图缓存" />
                <Button x:Name="ImportSelectedButton"
                        Margin="0,8,0,0"
                        Padding="8"
                        Click="OnImportSelectedClick"
                        Content="导入选中项" />
                <ProgressBar x:Name="LoadingProgress"
                             Margin="0,18,0,0"
                             Height="4"
                             IsIndeterminate="True"
                             Maximum="100"
                             Visibility="Collapsed" />
                <Separator Margin="0,22,0,18" />
                <TextBlock FontWeight="SemiBold" Text="缓存搜索" />
                <TextBox x:Name="SearchTextBox"
                         Margin="0,8,0,0"
                         Padding="8"
                         ToolTip="即使手机离线也可搜索文件名、相册和路径" />
                <Button x:Name="SearchButton"
                        Margin="0,8,0,0"
                        Padding="8"
                        Click="OnSearchClick"
                        Content="搜索本地索引" />
                <TextBlock x:Name="StatusText"
                           Margin="0,12,0,0"
                           Foreground="#4B5563"
                           Text="尚未连接"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>

            <Border x:Name="DevicePanel"
                    Padding="20"
                    Background="#F9FAFB"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DeviceNameText" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="DeviceModelText"
                                   Margin="0,6,0,0"
                                   Foreground="#6B7280" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock x:Name="BatteryText" HorizontalAlignment="Right" />
                        <TextBlock x:Name="MediaCountText"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <TextBlock x:Name="EmptyText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           Foreground="#6B7280"
                           Text="输入手机地址开始连接" />
                <TextBlock x:Name="TimelineFooterText"
                           Margin="0,0,0,8"
                           Padding="10,5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Background="#E5E7EB"
                           Foreground="#4B5563"
                           Visibility="Collapsed" />
                <ListBox x:Name="TimelineList"
                         ItemsSource="{Binding TimelineRows}"
                         SelectionMode="Extended"
                         BorderThickness="0"
                         Background="Transparent"
                         KeyDown="OnTimelineKeyDown"
                         MouseDoubleClick="OnTimelineDoubleClick"
                         ScrollViewer.ScrollChanged="OnTimelineScrollChanged"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.CacheLength="1,2"
                         Visibility="Collapsed">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <EventSetter Event="Loaded" Handler="OnTimelineItemLoaded" />
                            <EventSetter Event="Unloaded" Handler="OnTimelineItemUnloaded" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Margin="0,22,0,10"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="{Binding DateHeader}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DateHeader}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Margin="0,0,0,8"
                                        Padding="8"
                                        Background="#F9FAFB"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="144"
                                                Height="96"
                                                Background="#E5E7EB"
                                                CornerRadius="4"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill" />
                                                <TextBlock Padding="5,2"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Bottom"
                                                           Background="#99000000"
                                                           Foreground="White"
                                                           Text="{Binding TypeLabel}" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#6B7280"
                                                       Text="{Binding Details}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#6B7280"
                                                       Text="{Binding AlbumName}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Foreground="#6B7280"
                                                   Text="{Binding TakenAt}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="#F9FAFB"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="导入中心" />
                            <TextBlock x:Name="ImportSummaryText"
                                       Margin="12,3,0,0"
                                       Foreground="#6B7280"
                                       Text="暂无任务" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Padding="10,4"
                                    Click="OnPauseAllClick"
                                    Content="暂停全部" />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Click="OnResumeAllClick"
                                    Content="恢复全部" />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Click="OnClearCompletedClick"
                                    Content="清除已完成" />
                        </StackPanel>
                    </Grid>
                    <ListBox Grid.Row="1"
                             Margin="0,10,0,0"
                             ItemsSource="{Binding TransferRows}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="125" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11"
                                                   Foreground="#6B7280"
                                                   Text="{Binding StatusText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0"
                                                VerticalAlignment="Center">
                                        <ProgressBar Height="7"
                                                     Maximum="100"
                                                     Value="{Binding ProgressPercent}" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="11"
                                                   Foreground="#6B7280"
                                                   Text="{Binding ProgressText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Foreground="#4B5563"
                                               Text="{Binding RemainingText}" />
                                    <Button Grid.Column="3"
                                            Margin="8,0,0,0"
                                            Padding="7,3"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding CanRetry}"
                                            Tag="{Binding Id}"
                                            Click="OnRetryClick"
                                            Content="重试" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
