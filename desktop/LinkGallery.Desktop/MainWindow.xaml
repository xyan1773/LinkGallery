<Window x:Class="LinkGallery.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkGallery"
        Width="1100"
        Height="720"
        MinWidth="800"
        MinHeight="500"
        Closing="OnWindowClosing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="24" Background="#F3F4F6">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="LinkGallery" />
                <TextBlock Margin="0,28,0,0" FontWeight="SemiBold" Text="我的手机" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Text="通过同一 Wi-Fi 只读浏览手机中的照片和视频。" />
                <Separator Margin="0,22,0,18" />
                <TextBlock FontWeight="SemiBold" Text="连接地址" />
                <TextBox x:Name="AddressTextBox"
                         Margin="0,8,0,0"
                         Padding="8"
                         Text="192.168.1.20:39570"
                         ToolTip="手机显示的 IP 地址和端口" />
                <Button x:Name="ConnectButton"
                        Margin="0,12,0,0"
                        Padding="8"
                        Click="OnConnectClick"
                        Content="连接" />
                <Button x:Name="DisconnectButton"
                        Margin="0,8,0,0"
                        Padding="8"
                        IsEnabled="False"
                        Click="OnDisconnectClick"
                        Content="断开" />
                <Button Margin="0,8,0,0"
                        Padding="8"
                        Click="OnClearCacheClick"
                        Content="清理缩略图缓存" />
                <ProgressBar x:Name="LoadingProgress"
                             Margin="0,18,0,0"
                             Height="4"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />
                <TextBlock x:Name="StatusText"
                           Margin="0,12,0,0"
                           Foreground="#4B5563"
                           Text="尚未连接"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="DevicePanel"
                    Padding="20"
                    Background="#F9FAFB"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DeviceNameText" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="DeviceModelText"
                                   Margin="0,6,0,0"
                                   Foreground="#6B7280" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock x:Name="BatteryText" HorizontalAlignment="Right" />
                        <TextBlock x:Name="MediaCountText"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <TextBlock x:Name="EmptyText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           Foreground="#6B7280"
                           Text="输入手机地址开始连接" />
                <ListBox x:Name="TimelineList"
                         ItemsSource="{Binding TimelineRows}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.ScrollChanged="OnTimelineScrollChanged"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.CacheLength="1,2"
                         Visibility="Collapsed">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <EventSetter Event="Loaded" Handler="OnTimelineItemLoaded" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Margin="0,22,0,10"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="{Binding DateHeader}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DateHeader}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Margin="0,0,0,8"
                                        Padding="8"
                                        Background="#F9FAFB"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="144"
                                                Height="96"
                                                Background="#E5E7EB"
                                                CornerRadius="4"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill" />
                                                <TextBlock Padding="5,2"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Bottom"
                                                           Background="#99000000"
                                                           Foreground="White"
                                                           Text="{Binding TypeLabel}" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#6B7280"
                                                       Text="{Binding Details}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#6B7280"
                                                       Text="{Binding AlbumName}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Foreground="#6B7280"
                                                   Text="{Binding TakenAt}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
