<Window x:Class="LinkGallery.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkGallery"
        Width="1180"
        Height="760"
        MinWidth="800"
        MinHeight="560"
        Background="{StaticResource LgBrushCanvas}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationColumn" Width="76" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource LgBrushSurface}"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,1,0"
                MouseEnter="OnNavigationMouseEnter"
                MouseLeave="OnNavigationMouseLeave">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LgBrushInk}"
                               Text="LG" />
                    <TextBlock x:Name="ExpandedBrandText"
                               Margin="0,2,0,12"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="LinkGallery"
                               Visibility="Collapsed" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button AutomationProperties.AutomationId="NavGalleryButton"
                            Click="OnNavClick"
                            Content="G"
                            Style="{StaticResource LgNavButton}"
                            Tag="Gallery"
                            ToolTip="Gallery" />
                    <Button AutomationProperties.AutomationId="NavAlbumsButton"
                            Click="OnNavClick"
                            Content="A"
                            Style="{StaticResource LgNavButton}"
                            Tag="Albums"
                            ToolTip="Albums" />
                    <Button AutomationProperties.AutomationId="NavDevicesButton"
                            Click="OnNavClick"
                            Content="D"
                            Style="{StaticResource LgNavButton}"
                            Tag="Devices"
                            ToolTip="Devices" />
                    <Button AutomationProperties.AutomationId="NavTransfersButton"
                            Click="OnNavClick"
                            Content="T"
                            Style="{StaticResource LgNavButton}"
                            Tag="Transfers"
                            ToolTip="Transfers" />
                    <Button AutomationProperties.AutomationId="NavSettingsButton"
                            Click="OnNavClick"
                            Content="S"
                            Style="{StaticResource LgNavButton}"
                            Tag="Settings"
                            ToolTip="Settings" />
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="8"
                        Background="{StaticResource LgBrushAccentSoft}"
                        CornerRadius="{StaticResource LgRadiusMd}">
                    <StackPanel>
                        <TextBlock x:Name="DeviceStatusText"
                                   AutomationProperties.AutomationId="DeviceStatusText"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LgBrushAccent}"
                                   Text="Offline" />
                        <TextBlock x:Name="SyncStateText"
                                   Margin="0,3,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource LgBrushMuted}"
                                   Text="Local cache" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource LgBrushInk}"
                               Text="Gallery" />
                    <TextBlock x:Name="StatusText"
                               AutomationProperties.AutomationId="StatusText"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource LgBrushMuted}"
                               Text="Not connected"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1"
                        x:Name="DevicePanel"
                        Padding="14,10"
                        Background="{StaticResource LgBrushSurface}"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="{StaticResource LgRadiusLg}"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel>
                            <TextBlock x:Name="DeviceNameText" FontWeight="SemiBold" />
                            <TextBlock x:Name="DeviceModelText"
                                       FontSize="12"
                                       Foreground="{StaticResource LgBrushMuted}" />
                        </StackPanel>
                        <StackPanel Margin="22,0,0,0">
                            <TextBlock x:Name="BatteryText" HorizontalAlignment="Right" />
                            <TextBlock x:Name="MediaCountText"
                                       FontSize="12"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid x:Name="GalleryPage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="14"
                            Background="{StaticResource LgBrushSurface}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="{StaticResource LgRadiusLg}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="SearchTextBox"
                                         AutomationProperties.AutomationId="SearchTextBox"
                                         Width="260"
                                         Style="{StaticResource LgTextBox}"
                                         ToolTip="Search cached file names, albums and paths." />
                                <Button x:Name="SearchButton"
                                        AutomationProperties.AutomationId="SearchButton"
                                        Margin="8,0,0,0"
                                        Click="OnSearchClick"
                                        Content="Search"
                                        Style="{StaticResource LgSecondaryButton}" />
                                <ComboBox x:Name="TypeFilterComboBox"
                                          AutomationProperties.AutomationId="TypeFilterComboBox"
                                          Width="110"
                                          Margin="8,0,0,0"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="全部类型" Tag="all" />
                                    <ComboBoxItem Content="图片" Tag="image" />
                                    <ComboBoxItem Content="视频" Tag="video" />
                                </ComboBox>
                                <ComboBox x:Name="DateFilterComboBox"
                                          AutomationProperties.AutomationId="DateFilterComboBox"
                                          Width="130"
                                          Margin="8,0,0,0"
                                          SelectedIndex="0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="ImportSelectedButton"
                                        AutomationProperties.AutomationId="ImportSelectedButton"
                                        Click="OnImportSelectedClick"
                                        Content="Import selected"
                                        Style="{StaticResource LgCommandButton}" />
                                <TextBlock x:Name="SelectionSummaryText"
                                           AutomationProperties.AutomationId="SelectionSummaryText"
                                           Margin="12,8,0,0"
                                           Foreground="{StaticResource LgBrushMuted}"
                                           Text="0 selected" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock x:Name="EmptyText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="20"
                                   Foreground="{StaticResource LgBrushMuted}"
                                   Text="Enter a phone address to connect." />
                        <TextBlock x:Name="TimelineFooterText"
                                   Margin="0,0,0,8"
                                   Padding="10,5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Background="{StaticResource LgBrushSurfaceAlt}"
                                   Foreground="{StaticResource LgBrushMuted}"
                                   Visibility="Collapsed" />
                        <ListBox x:Name="TimelineList"
                                 AutomationProperties.AutomationId="TimelineList"
                                 ItemsSource="{Binding TimelineRows}"
                                 SelectionMode="Extended"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 KeyDown="OnTimelineKeyDown"
                                 MouseDoubleClick="OnTimelineDoubleClick"
                                 SelectionChanged="OnTimelineSelectionChanged"
                                 ScrollViewer.ScrollChanged="OnTimelineScrollChanged"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 Visibility="Collapsed">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="176" ItemHeight="236" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="AutomationProperties.AutomationId" Value="{Binding RemoteId}" />
                                    <Setter Property="AutomationProperties.Name" Value="{Binding FileName}" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,8,8" />
                                    <EventSetter Event="Loaded" Handler="OnTimelineItemLoaded" />
                                    <EventSetter Event="Unloaded" Handler="OnTimelineItemUnloaded" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="176"
                                            Height="236"
                                            Padding="8"
                                            Background="{StaticResource LgBrushSurface}"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource LgRadiusLg}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="132" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource LgBrushAccent}"
                                                       Text="{Binding DateHeader}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Row="1"
                                                    Margin="0,6,0,8"
                                                    Background="{StaticResource LgBrushSurfaceAlt}"
                                                    CornerRadius="{StaticResource LgRadiusMd}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                                    <TextBlock Padding="6,2"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Background="#99000000"
                                                               Foreground="White"
                                                               Text="{Binding TypeLabel}" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,3,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource LgBrushMuted}"
                                                           Text="{Binding Details}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource LgBrushMuted}"
                                                           Text="{Binding AlbumName}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Row="3"
                                                    AutomationProperties.AutomationId="OpenMediaButton"
                                                    Click="OnOpenMediaClick"
                                                    Content="Open"
                                                    Style="{StaticResource LgSecondaryButton}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>

                <Grid x:Name="AlbumsPage" Visibility="Collapsed">
                    <ItemsControl ItemsSource="{Binding AlbumRows}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="220" ItemHeight="120" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="212"
                                        Height="112"
                                        Margin="0,0,8,8"
                                        Padding="14"
                                        Background="{StaticResource LgBrushSurface}"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource LgRadiusLg}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{StaticResource LgBrushMuted}"
                                                   Text="{Binding CountText}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource LgBrushMuted}"
                                                   Text="{Binding TypeSummary}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Grid x:Name="DevicePage" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Padding="18"
                            Background="{StaticResource LgBrushSurface}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="{StaticResource LgRadiusLg}">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Connection" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       Text="Use 127.0.0.1:39570 for emulator ADB forwarding, or the phone Wi-Fi address for a physical device."
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,18,0,0" FontWeight="SemiBold" Text="Phone address" />
                            <TextBox x:Name="AddressTextBox"
                                     AutomationProperties.AutomationId="AddressTextBox"
                                     Margin="0,8,0,0"
                                     Style="{StaticResource LgTextBox}"
                                     Text="192.168.1.20:39570"
                                     TextChanged="OnAddressTextChanged"
                                     ToolTip="Phone IP address and port" />
                            <TextBlock x:Name="AddressHintText"
                                       Margin="0,7,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       TextWrapping="Wrap" />
                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                <Button x:Name="ConnectButton"
                                        AutomationProperties.AutomationId="ConnectButton"
                                        Click="OnConnectClick"
                                        Content="Connect"
                                        Style="{StaticResource LgCommandButton}" />
                                <Button x:Name="DisconnectButton"
                                        AutomationProperties.AutomationId="DisconnectButton"
                                        Margin="8,0,0,0"
                                        IsEnabled="False"
                                        Click="OnDisconnectClick"
                                        Content="Disconnect"
                                        Style="{StaticResource LgSecondaryButton}" />
                                <Button AutomationProperties.AutomationId="ClearThumbnailCacheButton"
                                        Margin="8,0,0,0"
                                        Click="OnClearCacheClick"
                                        Content="Clear thumbnails"
                                        Style="{StaticResource LgSecondaryButton}" />
                            </StackPanel>
                            <ProgressBar x:Name="LoadingProgress"
                                         Margin="0,18,0,0"
                                         Height="4"
                                         IsIndeterminate="True"
                                         Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Margin="14,0,0,0"
                            Padding="18"
                            Background="{StaticResource LgBrushSurface}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="{StaticResource LgRadiusLg}">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Pairing" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       Text="Pairing uses a short code from Android. Current trusted-device data will appear here after confirmation."
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,18,0,0"
                                       FontWeight="SemiBold"
                                       Text="Trusted desktop" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       Text="No paired desktop yet" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="TransfersPage" Visibility="Collapsed" />

                <Grid x:Name="SettingsPage" Visibility="Collapsed">
                    <Border Padding="18"
                            Background="{StaticResource LgBrushSurface}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="{StaticResource LgRadiusLg}">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Settings" />
                            <CheckBox Margin="0,14,0,0"
                                      Content="Reduce motion"
                                      IsChecked="False" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       Text="Motion is restrained by default; loading states use progress indicators instead of large transitions."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    x:Name="TransferDrawer"
                    AutomationProperties.AutomationId="TransferDrawer"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="{StaticResource LgBrushSurface}"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="{StaticResource LgRadiusLg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="TransferDrawerContentRow" Height="160" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Text="Transfers" />
                            <TextBlock x:Name="ImportSummaryText"
                                       AutomationProperties.AutomationId="ImportSummaryText"
                                       Margin="12,3,0,0"
                                       Foreground="{StaticResource LgBrushMuted}"
                                       Text="No jobs" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button AutomationProperties.AutomationId="ToggleTransferDrawerButton"
                                    Click="OnToggleTransferDrawerClick"
                                    Content="Collapse"
                                    Style="{StaticResource LgSecondaryButton}" />
                            <Button AutomationProperties.AutomationId="PauseAllButton"
                                    Margin="8,0,0,0"
                                    Click="OnPauseAllClick"
                                    Content="Pause all"
                                    Style="{StaticResource LgSecondaryButton}" />
                            <Button AutomationProperties.AutomationId="ResumeAllButton"
                                    Margin="8,0,0,0"
                                    Click="OnResumeAllClick"
                                    Content="Resume all"
                                    Style="{StaticResource LgSecondaryButton}" />
                            <Button AutomationProperties.AutomationId="ClearCompletedButton"
                                    Margin="8,0,0,0"
                                    Click="OnClearCompletedClick"
                                    Content="Clear completed"
                                    Style="{StaticResource LgSecondaryButton}" />
                        </StackPanel>
                    </Grid>
                    <ListBox Grid.Row="1"
                             x:Name="TransferList"
                             AutomationProperties.AutomationId="TransferList"
                             Margin="0,10,0,0"
                             ItemsSource="{Binding TransferRows}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="125" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock AutomationProperties.AutomationId="TransferStatusText"
                                                   FontSize="11"
                                                   Foreground="{StaticResource LgBrushMuted}"
                                                   Text="{Binding StatusText}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0"
                                                VerticalAlignment="Center">
                                        <ProgressBar Height="7"
                                                     Maximum="100"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource LgBrushMuted}"
                                                   Text="{Binding ProgressText}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource LgBrushMuted}"
                                               Text="{Binding RemainingText}" />
                                    <Button Grid.Column="3"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding CanRetry}"
                                            Tag="{Binding Id}"
                                            Click="OnRetryClick"
                                            Content="Retry"
                                            Style="{StaticResource LgSecondaryButton}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
