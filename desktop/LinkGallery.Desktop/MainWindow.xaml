<Window x:Class="LinkGallery.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinkGallery"
        Width="1100"
        Height="720"
        MinWidth="800"
        MinHeight="500"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="24" Background="#F3F4F6">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="LinkGallery" />
                <TextBlock Margin="0,28,0,0" FontWeight="SemiBold" Text="我的手机" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Text="通过同一 Wi-Fi 只读浏览手机中的照片和视频。" />
                <Separator Margin="0,22,0,18" />
                <TextBlock FontWeight="SemiBold" Text="连接地址" />
                <TextBox x:Name="AddressTextBox"
                         Margin="0,8,0,0"
                         Padding="8"
                         Text="192.168.1.20:39570"
                         TextChanged="OnAddressTextChanged"
                         ToolTip="手机显示的 IP 地址和端口" />
                <TextBlock x:Name="AddressHintText"
                           Margin="0,7,0,0"
                           FontSize="11"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Text="模拟器：先执行 adb forward，再输入 127.0.0.1:39570；不要输入 10.0.2.x。" />
                <Button x:Name="ConnectButton"
                        Margin="0,12,0,0"
                        Padding="8"
                        Click="OnConnectClick"
                        Content="连接" />
                <Button x:Name="DisconnectButton"
                        Margin="0,8,0,0"
                        Padding="8"
                        IsEnabled="False"
                        Click="OnDisconnectClick"
                        Content="断开" />
                <ProgressBar x:Name="LoadingProgress"
                             Margin="0,18,0,0"
                             Height="4"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />
                <Separator Margin="0,22,0,18" />
                <TextBlock FontWeight="SemiBold" Text="缓存搜索" />
                <TextBox x:Name="SearchTextBox"
                         Margin="0,8,0,0"
                         Padding="8"
                         ToolTip="即使手机离线也可搜索文件名、相册和路径" />
                <Button x:Name="SearchButton"
                        Margin="0,8,0,0"
                        Padding="8"
                        Click="OnSearchClick"
                        Content="搜索本地索引" />
                <TextBlock x:Name="StatusText"
                           Margin="0,12,0,0"
                           Foreground="#4B5563"
                           Text="尚未连接"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="DevicePanel"
                    Padding="20"
                    Background="#F9FAFB"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DeviceNameText" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="DeviceModelText"
                                   Margin="0,6,0,0"
                                   Foreground="#6B7280" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock x:Name="BatteryText" HorizontalAlignment="Right" />
                        <TextBlock x:Name="MediaCountText"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <TextBlock x:Name="EmptyText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           Foreground="#6B7280"
                           Text="输入手机地址开始连接" />
                <DataGrid x:Name="MediaGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Visibility="Collapsed">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="90" Header="类型" Binding="{Binding Type}" />
                        <DataGridTextColumn Width="*" Header="文件名" Binding="{Binding FileName}" />
                        <DataGridTextColumn Width="110" Header="大小" Binding="{Binding DisplaySize}" />
                        <DataGridTextColumn Width="130" Header="尺寸/时长" Binding="{Binding Details}" />
                        <DataGridTextColumn Width="170" Header="拍摄时间" Binding="{Binding TakenAt}" />
                        <DataGridTextColumn Width="140" Header="相册" Binding="{Binding AlbumName}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>
